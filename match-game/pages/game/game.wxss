/* pages/game/game.wxss */
.game-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.level-badge {
  font-size: 28rpx;
  font-weight: bold;
  color: #6c5ce7;
  background: #f0f0ff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.header-center, .header-right {
  text-align: center;
}

.score-label, .target-label {
  display: block;
  font-size: 22rpx;
  color: #636e72;
}

.score-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #00b894;
}

.target-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fdcb6e;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00b894, #00cec9);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 连击显示 */
.combo-display {
  position: absolute;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(253, 203, 110, 0.95);
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  z-index: 100;
  animation: combo-pop 0.5s ease;
}

@keyframes combo-pop {
  0% { transform: translateX(-50%) scale(0); opacity: 0; }
  50% { transform: translateX(-50%) scale(1.2); }
  100% { transform: translateX(-50%) scale(1); opacity: 1; }
}

.combo-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2d3436;
  text-align: center;
}

.combo-bonus {
  display: block;
  font-size: 28rpx;
  color: #e17055;
  text-align: center;
}

/* 游戏棋盘 */
.game-board {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 30rpx;
}

.board-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.board-row:last-child {
  margin-bottom: 0;
}

/* 方块样式 */
.tile {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
  cursor: pointer;
}

.tile:active {
  transform: scale(0.9);
}

/* 颜色方案 */
.color-0 {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
}

.color-1 {
  background: linear-gradient(135deg, #4ecdc4, #44a08d);
}

.color-2 {
  background: linear-gradient(135deg, #45b7d1, #96c93d);
}

.color-3 {
  background: linear-gradient(135deg, #f9ca24, #f0932b);
}

.color-4 {
  background: linear-gradient(135deg, #a55eea, #8854d0);
}

.color-5 {
  background: linear-gradient(135deg, #fd79a8, #e84393);
}

/* 图标 */
.tile-icon {
  font-size: 40rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 选中状态 */
.tile.selected {
  transform: scale(1.15);
  box-shadow: 0 0 0 4rpx #fff, 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: pulse 0.6s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1.15); }
  50% { transform: scale(1.25); }
}

/* 消除动画 */
.tile.eliminating {
  animation: eliminate 0.4s ease forwards;
}

@keyframes eliminate {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.8; }
  100% { transform: scale(0); opacity: 0; }
}

/* 下落动画 */
.tile.falling {
  animation: fall 0.3s ease;
}

@keyframes fall {
  0% { transform: translateY(-100rpx); }
  100% { transform: translateY(0); }
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 30rpx;
}

.control-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #2d3436;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 20rpx 50rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  border: none;
}

.control-btn::after {
  border: none;
}

.control-btn.restart {
  background: linear-gradient(135deg, #fdcb6e, #f39c12);
  color: #fff;
}

.control-btn.back {
  background: rgba(255, 255, 255, 0.9);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-content.success {
  border-top: 8rpx solid #00b894;
}

.modal-content.fail {
  border-top: 8rpx solid #e17055;
}

.modal-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #2d3436;
  margin-bottom: 20rpx;
}

.modal-score {
  display: block;
  font-size: 36rpx;
  color: #636e72;
  margin-bottom: 10rpx;
}

.modal-message {
  display: block;
  font-size: 28rpx;
  color: #b2bec3;
  margin-bottom: 40rpx;
}

.modal-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-btn {
  width: 100%;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 25rpx 0;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #00b894 0%, #00cec9 100%);
  color: #fff;
}

.modal-btn.secondary {
  background: #f0f0f0;
  color: #636e72;
}
