/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.title-section {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.game-title {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 16rpx;
}

.game-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.level-section {
  margin-bottom: 60rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  text-align: center;
}

.level-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.level-card {
  width: 30%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s;
}

.level-card:active {
  transform: scale(0.95);
}

.level-card.locked {
  background: rgba(255, 255, 255, 0.5);
  opacity: 0.7;
}

.level-card.selected {
  background: #00b894;
  color: #fff;
}

.level-card.selected .level-number,
.level-card.selected .level-status,
.level-card.selected .level-target {
  color: #fff;
}

.level-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #2d3436;
  margin-bottom: 8rpx;
}

.level-status {
  display: block;
  font-size: 24rpx;
  color: #636e72;
  margin-bottom: 8rpx;
}

.level-target {
  display: block;
  font-size: 22rpx;
  color: #b2bec3;
}

.button-section {
  margin-bottom: 60rpx;
}

.start-btn {
  background: linear-gradient(135deg, #00b894 0%, #00cec9 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 30rpx 80rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 184, 148, 0.4);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.start-btn::after {
  border: none;
}

.btn-text {
  font-size: 36rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.tips-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.tips-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}
